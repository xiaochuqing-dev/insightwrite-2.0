# Copy this file to .env and replace the placeholder values before starting locally.
# Do not commit .env.

DB_USERNAME=insightwrite
DB_PASSWORD=change_this_database_password

JWT_SECRET=change_this_to_at_least_32_bytes_for_local_dev_123456

DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

MAIL_USERNAME=replace_with_your_smtp_account
MAIL_PASSWORD=replace_with_your_smtp_authorization_code
MAIL_PORT=465

SQL_INIT_MODE=never
